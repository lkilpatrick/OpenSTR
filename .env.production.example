# OpenSTR Production Environment
# Copy to .env.production and fill in real values

# Domain — your public domain or IP
DOMAIN=openstr.yourdomain.com

# Database
POSTGRES_USER=openstr
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=openstr

# JWT / Auth — generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
BETTER_AUTH_SECRET=CHANGE_ME_32_CHARS
BETTER_AUTH_URL=https://openstr.yourdomain.com
ADMIN_URL=https://openstr.yourdomain.com

# CORS — the origins that can call the API
ALLOWED_ORIGINS=https://openstr.yourdomain.com

# Webhooks
WEBHOOK_SECRET=CHANGE_ME

# Photo uploads — max file size also controlled by nginx (client_max_body_size)
PHOTO_STORAGE_PATH=/photos
