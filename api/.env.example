# Database
DATABASE_URL=postgres://openstr:password@localhost:5432/openstr
POSTGRES_USER=openstr
POSTGRES_PASSWORD=password
POSTGRES_DB=openstr
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT / Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
BETTER_AUTH_SECRET=change-me-32-char-random-string-here
BETTER_AUTH_URL=http://localhost:3000

# Server
PORT=3000
NODE_ENV=development
ADMIN_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# File Storage
PHOTO_STORAGE_PATH=/photos

# Webhooks (Home Assistant, etc.)
WEBHOOK_SECRET=change-me-in-production
